<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <PackageId>StackedDeck.Project.Templates</PackageId>
        <PackageVersion>0.0.9</PackageVersion>
        <Title>Stacked Deck Project Templates</Title>
        <Authors>Vasil Kotsev</Authors>
        <Description>.NET Project templates, composed to give you advantage akin to a "stacked card deck".</Description>
        <PackageTags>dotnet;templates;aspnet-core;web-api;containers;docker;production;csharp;stacked-deck</PackageTags>
        <PackageIcon>assets\sd-logo-7.png</PackageIcon>
        <PackageProjectUrl>https://github.com/SonnyRR/stacked-deck-templates/</PackageProjectUrl>
        <RepositoryUrl>https://github.com/SonnyRR/stacked-deck-templates</RepositoryUrl>
        <Copyright>Copyright (c) Vasil Kotsev 2025</Copyright>
        <PackageLicenseFile>LICENSE</PackageLicenseFile>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageType>Template</PackageType>
        <TargetFramework>net10.0</TargetFramework>
        <IncludeContentInPack>true</IncludeContentInPack>
        <IncludeBuildOutput>false</IncludeBuildOutput>
        <ContentTargetFolders>content</ContentTargetFolders>
        <NoWarn>$(NoWarn);NU5128</NoWarn>
        <NoDefaultExcludes>true</NoDefaultExcludes>
        <PackageReleaseNotes>
🔧 Chores
- Bump Microsoft.NET.Test.Sdk to v18.4.0 (f39322e)
- Bump Azure Identity to v1.21.0 (7cf1336)
- Bump Destructurama.Attributed to v5.3.0 (a1e9ca8)
- Bump Microsoft.AspNetCore.Mvc.Testing to v10.0.6 (5dca4a7)
- Bump Scalar.AspNetCore to v2.14.1 (7864029, 1ac6adb, 58d5d61)
- Bump coverlet.collector to v10.0.0 (a23d90d)
- Bump GHA workflow actions (68de2d0)
- Multiple 3rd party dependency bumps (25a0d6a)
        </PackageReleaseNotes>
    </PropertyGroup>

    <PropertyGroup>
        <LocalizeTemplates>false</LocalizeTemplates>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.TemplateEngine.Tasks" Version="7.0.120" PrivateAssets="all" IsImplicitlyDefined="true"/>
    </ItemGroup>

    <ItemGroup>
        <Content Include="content\**\*" Exclude="content\**\bin\**;content\**\obj\**;content\**\packages\**;content\**\pkg\**;**\.vs\**;content\**\.DS_Store;content\**\publish\**"/>
        <Compile Remove="**\*"/>
    </ItemGroup>

    <ItemGroup>
        <None Include="LICENSE" Pack="true" PackagePath=""/>
        <None Include="PKG_README.md" Pack="true" PackagePath=".\README.md"/>
        <None Include="content\StackedDeck.WebAPI\.template.config\sd-logo-7.png" Pack="true" PackagePath="assets\"/>
    </ItemGroup>

</Project>
