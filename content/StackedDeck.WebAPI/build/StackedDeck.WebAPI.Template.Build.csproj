<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace></RootNamespace>
    <!--
      'NU1901 & 'NU1903' are temporarily included in this list until a new version
      of 'NUKE' is released or this project is migrated to 'Fallout'.
    -->
    <NoWarn>CS0649;CS0169;CA1050;CA1822;CA2211;IDE1006;NU1901;NU1903</NoWarn>
    <NukeRootDirectory>..\</NukeRootDirectory>
    <NukeScriptDirectory>..</NukeScriptDirectory>
    <NukeTelemetryVersion>1</NukeTelemetryVersion>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Nuke.Common" Version="10.1.0" />
    <PackageReference Include="Polly" Version="8.7.0" />
  </ItemGroup>

  <ItemGroup>
    <PackageDownload Include="GitVersion.Tool" Version="[6.8.2]" />
    <PackageDownload Include="ReportGenerator" Version="[5.5.10]" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="..\.github\dependabot.yml">
      <Link>ci\dependabot.yml</Link>
    </Content>
  </ItemGroup>
</Project>
