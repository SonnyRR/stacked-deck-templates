<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace></RootNamespace>
    <NoWarn>CS0649;CS0169;CA1050;CA1822;CA2211;IDE1006</NoWarn>
    <FalloutRootDirectory>..\</FalloutRootDirectory>
    <FalloutScriptDirectory>..</FalloutScriptDirectory>
    <FalloutTelemetryVersion>1</FalloutTelemetryVersion>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Fallout.Common" Version="10.3.49" />
    <PackageReference Include="Polly" Version="8.7.0" />
  </ItemGroup>

  <ItemGroup>
    <PackageDownload Include="GitVersion.Tool" Version="[6.8.2]" />
    <PackageDownload Include="ReportGenerator" Version="[5.5.10]" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="..\.github\dependabot.yml">
      <Link>ci\dependabot.yml</Link>
    </Content>
  </ItemGroup>
</Project>
